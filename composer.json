{
    "name": "psc-acme/connector-cart",
    "description": "Package connector-cart for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ConnectorCart\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "symfony/dotenv": "^7.0",
        "carbon/carbon": "^3.0"
    },
    "require-dev": {
        "behat/behat": "^3.14",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}